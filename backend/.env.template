# === Litetube — environment template ===
# Copy to .env, fill PLACEHOLDER values, NEVER commit .env to git.
#
#   cp .env.template .env
#   openssl rand -hex 32              # paste as JWT_SECRET
#   ./scripts/init_operator.py         # generates OPERATOR_PASSWORD_HASH
#
# The /srv/proxy-infra/.env file is mounted into both containers via env_file: directive.

# ----- general -----
LITETUBE_ENV=production
LITETUBE_LOG_LEVEL=INFO

# ----- JWT auth -----
# openssl rand -hex 32
JWT_SECRET=<REPLACE_WITH_OPENSSL_RAND_HEX_32>
JWT_EXPIRY_HOURS=24

# ----- operator (admin) -----
# Created/synced by scripts/init_operator.py
OPERATOR_EMAIL=admin@litetube.trfnv.ru
# Bcrypt hash (cost 10) — generated; never commit raw password
OPERATOR_PASSWORD_HASH=<REPLACE_WITH_BCRYPT_HASH>

# ----- Robokassa -----
# test-mode credentials (separate from production)
ROBOKASSA_SHOP_ID=<REPLACE_ME_LITETUBE_SHOP_ID>
ROBOKASSA_PASSWORD1=<REPLACE_ME>
ROBOKASSA_PASSWORD2=<REPLACE_ME>
ROBOKASSA_TEST_MODE=1
ROBOKASSA_RESULT_URL=https://litetube.trfnv.ru/api/billing/webhook
ROBOKASSA_SUCCESS_URL=https://litetube.trfnv.ru/billing/success
ROBOKASSA_FAIL_URL=https://litetube.trfnv.ru/billing/fail

# ----- Billing provider switch -----
# "mock" =  /api/admin/billing/simulate hits the webhook flow locally
# "robokassa" = real Robokassa redirects & webhooks
BILLING_PROVIDER=mock

# ----- Trial / pricing -----
TRIAL_DURATION_DAYS=3
PRICE_RUB=199
PRICE_USD=3.99
PRICE_EUR=3.99

# ----- 3proxy ports (host-network bound) -----
THREEPROXY_PID_PATH=/var/lib/3proxy/3proxy.pid
THREEPROXY_CFG_PATH=/var/lib/3proxy/3proxy.cfg
THREEPROXY_SOCKS5_PORT=11001
THREEPROXY_HTTP_PORT=11002

# ----- Health-checker -----
HEALTH_CHECK_INTERVAL_SEC=30
HEALTH_CHECK_TIMEOUT_SEC=8

# ----- Rate-limit -----
RATE_LIMIT_PER_IP_PER_MIN=60
FAILED_AUTH_THRESHOLD_PER_HOUR=20

# ----- proxy host -----
# The public IP or domain name of the proxy server returned to clients
PROXY_HOST=82.202.141.81

# ----- nginx → FastAPI -----
# nginx vhosts proxy_pass to http://127.0.0.1:9090
# These DOMAINS must be TLS-secured by certbot.
PUBLIC_DOMAINS=litetube.trfnv.ru,admin.litetube.trfnv.ru,api.litetube.trfnv.ru

# ===== Alerter =====
# Plug zero or ONE of: SMTP (smtplib), HTTP webhook. JSONL log sink is
# always-on regardless. All knobs consumed by both the in-process alert
# loops (api/litetube/alert_loops.py) AND the host-side alert_daemon
# (scripts/alert_daemon.py) — they share the SQLite alert_state table
# for cooldown so a burst produces exactly one alert, not fifty.

ALERT_HOSTNAME=litetube-82-202-141-81
# 0 to disable cooldown (always emit). Default 30 min.
ALERT_COOLDOWN_SEC=1800
# JSONL append path inside container (FastAPI writes here) and on host
# (daemon writes here). Mounted via /srv/proxy-infra/logs volume.
ALERT_LOG_PATH=/var/log/litetube/alerts.jsonl

# ----- SMTP (optional; leave blank to skip) -----
# ALERT_SMTP_HOST=smtp.yandex.ru
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=alerts@litetube.trfnv.ru
# ALERT_SMTP_PASS=<REPLACE_ME_APP_PASSWORD>
# ALERT_SMTP_FROM=alerts@litetube.trfnv.ru
# ALERT_SMTP_TLS=1
# ALERT_SMTP_TIMEOUT=10
# ALERT_EMAIL_TO=ops@litetube.trfnv.ru

# ----- Webhook (optional; works with Twilio SMS-via-Twimlet, SMS.ru,
#       Slack incoming webhook, Telegram bot API, Discord, PagerDuty) -----
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX
# ALERT_WEBHOOK_TIMEOUT=10

# ----- Tunables for the in-process polling loops -----
ALERT_PROXY_FAILURE_TICKS=10
ALERT_PROXY_OUTAGE_SCAN_SEC=60
ALERT_DAILY_ZERO_HOUR_UTC=1
ALERT_DAILY_ZERO_SCAN_SEC=600

# ===== Device activation (TV-client ↔ web pairing) =====
# Lifetime of a /api/devices/start code (TV-side).
DEVICE_CLAIM_TTL_SEC=600
# How long /api/devices/poll holds the connection open per tick.
DEVICE_POLL_MAX_SEC=30
# Sleep between DB re-checks inside the long-poll loop.
DEVICE_POLL_TICK_MS=400
# Quick rate-limit window for /api/devices/start (per IP per minute).
DEVICE_START_PER_IP_PER_MIN=12
# Public base URL prepended to QR codes. No trailing slash.
DEVICE_ACTIVATE_BASE_URL=https://litetube.trfnv.ru/activate
# Maximum number of proxy entries returned by /api/proxy/pool.
# Today we serve the user's primary only; future shared fallbacks slot in here.
PROXY_POOL_SIZE=3

# ===== Google Sign-In (Этап 1: disabled by default; safe rollback via flag) =====
# Set GOOGLE_AUTH_ENABLED=1 to expose POST /api/auth/google. While 0 the
# endpoint returns 404 — no schema change, no network call, no behaviour
# drift vs prior releases. Flip with confidence: this is the rollback lever
# for Этап 1 if any security regression is found in production.
GOOGLE_AUTH_ENABLED=0
# OAuth 2.0 Web Client ID from console.cloud.google.com → APIs & Services →
# Credentials. Must match `Authorized JavaScript origins` set to
# `https://litetube.trfnv.ru` (no path, no trailing slash). Paste the full
# `...apps.googleusercontent.com` string. Leave empty when the flag is 0.
GOOGLE_CLIENT_ID=
